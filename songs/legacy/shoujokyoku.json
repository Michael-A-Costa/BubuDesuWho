  "lyrics": [
    "[call]({Wake} {Up,} {Girls!})\n[end-call]",
    "{Mada honno josou dakara kowai nante itte nai}",
    "{Takanaru mune no kodou seifuku de sotto kakushite}",
    "{PORIFONIKKU na yume ni obore jibun ga mienaku naru no}",
    "[call][push,15em]({yume ni obore})[end-call]",
    "{Kore ga hatsukoi de nakattara subete wo nugisuteru no ni}",
    "[call][push,13.5em]({Hai~!} {Hai~!} {Hai!} {Hai!} {Hai!} {Hai!})[end-call]",
    "",
    "{Yureru shoujo no kimochi GARASU no you ni moroku itai}",
    "[call]({Oooh} {hai!} {Oooh} {hai!} {Oooh} {hai!} {Oooh} {hai!})[end-call]",
    "{Konomama ja} [together]{(kokucchae cha chae!)}",
    "{Koware sou} [together]{(anata nara kitto daijoubu!)}",
    "{Mou watashi} [together]{(bakuhatsu sunzen!)}",
    "{afureru...!}",
    "",
    "[together]{(PAPPARAPPAPPARAPPA!)}",
    "{Ippai nayanda hibi wa} {kesshite muda ja nai kara}",
    "[call][push,7em]({Oooh} {fufu!}) [push,2em]({Seno} {fuwa} {fuwa} {fuwa} {fuwa})[end-call]",
    "{Egao dake wa kyou mo CHAAJI shite} {fuan to butsukaru}",
    "[together]{(You, Never never give up!)}",
    "{Arinomama wo dasu no wa} {totemo yuuki iru kedo}",
    "[call][push,7em]({Oooh} {fufu!}) [push,2em]({Seno} {fuwa} {fuwa} {fuwa} {fuwa})[end-call]",
    "{Yappa sunao na jibun mite hoshii kimi ni todoketai}",
    "[call][push,20em]({Fu~}{fu}{fu!})[end-call]",
    "{Hajimete no SHINFONII}",
    "",
    "{DOMINANTO no hibiki tsudzuki modokashisa ni mi wo yojiru}",
    "{Kimi to mitsumeatte kara toki wa nagare yuuhi wa shizumi}",
    "{DEMOONISSHU na kaze ni furue SUKAATO no naka zawatsuku}",
    "[call][push,13em]({kaze ni furue})[end-call]",
    "{Demo ne kimeta no kono CHANSU de kimi no omoi shiritai to}",
    "[call][push,17em]({Hai~!} {Hai~!} {Hai!} {Hai!} {Hai!} {Hai!})[end-call]",
    "",
    "{\"Tada no tomodachi de\" nante yoku aru kurishe wa kikitakunai}",
    "[call]({Oooh} {hai!} {Oooh} {hai!} {Oooh} {hai!} {Oooh} {hai!})[end-call]",
    "{Wagamama na} [together]{(ato ni shirizokenai kenakenai!)}",
    "{Shoujo da to} [together]{(anata no honki misechae!)}",
    "{Omowarete} [together]{(mou hito oshi jan!)}",
    "{ii kara...!}",
    "",
    "[next-col][together]{(BANBABANBONBABANBON!)}",
    "{Hontou ni daiji na mono wa} {itsumo mieru wake ja nai}",
    "[call][push,7em]({Oooh} {fufu!}) [push,2em]({Seno} {fuwa} {fuwa} {fuwa} {fuwa})[end-call]",
    "{Dakara ima no jibun shinjite} {mirai wo shinjite}",
    "[together]{(You, Never never look back!)}",
    "{Motomeru kokoro areba} {kanashimi mo samishisa mo}",
    "[call][push,7em]({Oooh} {fufu!}) [push,2em]({Seno} {fuwa} {fuwa} {fuwa} {fuwa})[end-call]",
    "{Kitto utsukushii keshiki ni kawaru kimi to tsumugidasu}",
    "[call][push,22em]({Fu~}{fu}{fu!})[end-call]",
    "{Toumei na SHINFONII}",
    "",
    "{Utagau koto oboetara kirinai kedo}",
    "{Minna yowai yo ne watashi mo onaji}",
    "{Hito to hito to ga tsunagaru tte kiseki}",
    "{Tsugi no shunkan} {kono te wa hanareru kara}",
    "{Gomen, sayonara}",
    "",
    "[call]({Hai!} {Hai!} {Hai!} {Hai!})[end-call]",
    "[call]({Hai!} {Hai!} {Hai!} {Hai!})[end-call]",
    "[call]({Hai!} {Hai!} {Hai!} {Hai!})\n[end-call]",
    "{Hitotsu hitotsu no oto wo ookina FUUGA ni shiyou}",
    "{Jibun no yowasa sarakedashite demo kimi to tsunagarou}",
    "",
    "{(You, Never never give up!)}",
    "[together]{(You, Never never give up!)}",
    "",
    "{Ippai nayanda hibi wa} {kesshite muda ja nai kara}",
    "[call][push,7em]({Oooh} {fufu!}) [push,2em]({Seno} {fuwa} {fuwa} {fuwa} {fuwa})[end-call]",
    "{Egao dake wa kyou mo CHAAJI shite fuan to butsukaru}",
    "[together]{(You, Never never give up!)}",
    "{Arinomama wo dasu no wa} {totemo yuuki iru kedo}",
    "[call][push,7em]({Oooh} {fufu!}) [push,2em]({Seno} {fuwa} {fuwa} {fuwa} {fuwa})[end-call]",
    "{Yappa sunao na jibun mite hoshii kimi ni todoketai}",
    "[call][push,22em]({Fu~}{fu}{fu!})[end-call]",
    "{Hajimete no SHINFONII}"
  ],
