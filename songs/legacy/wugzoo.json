  "lyrics": [
    "{Wansaka wansaka wansaka wansaka}",
    "{Korya taihen da}",
    "",
    "{Machi no hazure no nazo no doubutsuen sa}",
    "{One two maniakku tsuugo nomi nano sa}",
    "{Taiyou san san hiru ne shichatteru kamo}",
    "{Soko mo yoroshiku kutsuroi de itte}",
    "",
    "{Moshi moya moya to suru koto ga}",
    "{Saru yama no youni ippai datte waracchatte yo ne!}",
    "",
    "{Dare mo kare mo dore mo koyui kyara darake sa}",
    "{Ano ne hora ne goran jitsu wa hakuchou tachi mo}",
    "{Oike no naka de hisshi koi de iru yo}",
    "{Wansaka wansaka wansaka wansaka taihen da}",
    "{Wansaka wansaka wansaka wansaka WUG ZOO ZOO}",
    "",
    "{Buta mo odaterya ten ni nobocchau nda}",
    "{Washi mo homerare uchouten rando}",
    "{Uma ga awanai hito ga tonari ni ite mo}",
    "{Pinchi kugureba nakama ni nareru}",
    "",
    "{Arya wara wara to atsumattara}",
    "{Sagina yatsu tsume de hikkaite yattsuke chaou ne!}",
    "",
    "{Are mo kore mo sore mo dore mo omoi de ni naru}",
    "{Shashin torou nan ya kan ya keiken shiyou}",
    "{Fuyu no shirokuma natsu mo shirokuma}",
    "{Nandaka nandaka nandaka nandaka tanoshii na}",
    "{Wansaka wansaka wansaka wansaka WUG ZOO ZOO}",
    "",
    "{Toki wa kikan gentei sa}",
    "{Mou nidoto dekinai kamo} {kono shun na pouzu}",
    "{Chansu sore wa isshun sa}",
    "{Saa ima da tsukamaete yo ne} {chanto mite ne}",
    "{Fuwa fuwa fuwa fuwa naka no hito nado inai}",
    "",
    "{Moshi chizu wo nakushite ite mo}",
    "{Daijoubu} {tsuyoku negaeba tadori tsukeru yo}",
    "{Fushigi}",
    "",
    "{Are mo kore mo sore mo dore mo omoi de ni naru}",
    "{Shashin torou nan ya kan ya keiken shiyou}",
    "{Itsumo nando mo omoi dashite ne}",
    "{Nandaka nandaka nandaka nandaka tanoshii na}",
    "{Wansaka wansaka wansaka wansaka WUG ZOO ZOO}",
    "{Nanda kanda wonder thunder WUG ZOO ZOO}"
  ]
